# Wayfind environment. Copy to .env.local and fill what you have.
# The app runs WITHOUT any of these — set ANTHROPIC_API_KEY for live AI generation,
# otherwise a built-in deterministic generator produces itineraries offline.

# --- AI ---
ANTHROPIC_API_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Affiliate IDs (optional; URLs are built with or without them) ---
TRAVELPAYOUTS_MARKER=
BOOKING_AFFILIATE_ID=
VIATOR_PARTNER_ID=
GYG_PARTNER_ID=
OPENTABLE_AFFILIATE_ID=
AIRALO_AFFILIATE_ID=
SAFETYWING_AFFILIATE_ID=
AMAZON_ASSOCIATE_TAG=

# --- Production services (not required to run locally; see README) ---
# DATABASE_URL=
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# NEXT_PUBLIC_MAPBOX_TOKEN=
# UNSPLASH_ACCESS_KEY=
# RESEND_API_KEY=
# SENTRY_DSN=
# NEXT_PUBLIC_POSTHOG_KEY=
RESEND_API_KEY=
RESEND_FROM=Stitch <onboarding@resend.dev>
SUPPORT_FORWARD_EMAIL=leonrou87@gmail.com
